[user]
  name = Sendy Halim
  email = sendyhalim93@gmail.com

[core]
  excludesfile = ~/.gitignore
  pager = delta

[status]
  showUntrackedFiles = all

[color]
  ui = true

[color "branch"]
  current = blue
  local = yellow
  remote = green

# [color "diff"]
#   meta = yellow
#   frag = magenta
#   old = 243
#   new = 45

[color "status"]
  added = 45
  changed = 78
  untracked = 243

[pull]
  rebase = true

[diff]
  tool = icdiff

[interactive]
  diffFilter = delta --color-only

[delta]
  navigate = true                                    # use n and N to move between diff sections
  true-color = always                                # force 24-bit color
  line-numbers = true                                # show line numbers
  file-style = "bold green"                          # filename header color
  file-decoration-style = "#aaaaaa ul"               # underline below filename
  hunk-header-line-number-style = "#aaaaaa"          # line number in hunk header
  hunk-header-decoration-style = "#aaaaaa box"       # box around hunk header

  # Added lines: purely new line = green bg
  plus-style = "bold white" "#007700"
  # Changed lines: unchanged words = blue bg
  plus-non-emph-style = "bold white" "#0055cc"
  # Changed lines: the specific changed words = green bg
  plus-emph-style = "bold white" "#007700"

  # Line number gutter colors
  line-numbers-plus-style = "bold white" "#007700"   # added line numbers = green
  line-numbers-left-style = "#aaaaaa"                # left gutter (old)
  line-numbers-right-style = "#aaaaaa"               # right gutter (new)

[merge]
  conflictStyle = zdiff3

[difftool]
  prompt = false

[difftool "icdiff"]
  cmd = icdiff --line-numbers $LOCAL $REMOTE

[alias]
  a    = add
  b    = branch
  bm   = branch --move
  branch-delete-with-pattern = "!f() { git branch -D $(git branch | grep $1); }; f"
  cl   = clone
  c    = commit --verbose
  cm   = commit -m
  ca   = commit -am
  cam  = commit --amend
  cv   = commit --verbose
  co   = checkout
  cob  = checkout -b
  com  = checkout master
  cp   = cherry-pick
  d    = diff
  ds   = -c delta.side-by-side=true diff
  db   = diff HEAD~1..HEAD
  dbf  = diff HEAD~1..HEAD --name-status
  dc   = diff --cached
  dm   = diff master..HEAD
  l    = log --oneline --decorate --color --graph
  lg   = log --stat --max-count=10
  lgg  = log --graph --max-count=10
  lgga = log --graph --decorate --all
  lo   = log --oneline --decorate --color
  ls-untracked = !git ls-files --others --exclude-standard
  p    = push
  po   = push origin
  pom  = push origin master
  pl   = pull
  rb   = rebase
  rbm  = rebase master
  s    = status
  ss   = status -s
  st   = stash
  standup = !git log --author="$(git config --global user.email)" --oneline --since="yesterday" --all
  stash-all = stash save --include-untracked
  t    = tag
  td   = tag -d # Delete tag
  tdr  = push --delete origin
  delete-remote-tag = push --delete origin
  undo = reset --soft HEAD^
  unstage = restore --staged
